# Copy to .env.local and fill in real values. Never commit secrets.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service-role key. Server-only — bypasses RLS. Used by the admin routes,
# the cron purge endpoint, and the storage validation/cleanup logic.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=PeerHelp

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret required by /api/admin/cron/purge-documents.
# Vercel Cron should send `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=
